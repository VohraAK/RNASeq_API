DATABASE_URL=postgresql+asyncpg://rnaseq:change-me-to-a-strong-password@db:5432/rnaseq_db
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ALLOWED_ORIGINS=http://localhost:3000
UPLOAD_DIR=/var/rnaseq/uploads
