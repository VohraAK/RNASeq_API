DATABASE_URL=postgresql+asyncpg://rnaseq:change-me-to-a-strong-password@db:5432/rnaseq_db
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ALLOWED_ORIGINS=http://localhost:3000,null  # add null to allow dev_ui.html opened from file://
UPLOAD_DIR=/var/rnaseq/uploads
REDIS_URL=redis://redis:6379/0
COOKIE_SECURE=false  # set to true in production (requires HTTPS)

# Postgres container credentials (used by docker-compose db service)
POSTGRES_USER=rnaseq
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=rnaseq_db
